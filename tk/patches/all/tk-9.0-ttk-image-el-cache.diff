+/* Ttk_ElementClassCacheable --
+ *	Return nonzero if the element class opted into per-node render caching.
+ */
+int Ttk_ElementClassCacheable(Ttk_ElementClass *eclass)
+{
+    return (eclass->cacheFlags & TTK_ELEMENT_CACHEABLE) != 0;
+}
