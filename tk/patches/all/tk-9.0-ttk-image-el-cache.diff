+    dst = Ttk_StickBox(b, imgWidth, imgHeight, imageData->sticky);
+    if (dst.x == b.x && dst.y == b.y
+	    && dst.width == b.width && dst.height == b.height) {
+	info->opaque = ImageIsOpaque(Tk_Interp(tkwin),
+		TtkSelectImageName(imageData->imageSpec, state));
+    }
+}
