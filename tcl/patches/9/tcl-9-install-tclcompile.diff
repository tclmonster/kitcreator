diff -ur tcl9.0.3.orig/unix/Makefile.in tcl9.0.3/unix/Makefile.in
--- tcl9.0.3.orig/unix/Makefile.in
+++ tcl9.0.3/unix/Makefile.in
@@ -1183,7 +1183,7 @@
 TCL_PRIVATE_HEADERS = $(GENERIC_DIR)/tclInt.h $(GENERIC_DIR)/tclIntDecls.h \
 	$(GENERIC_DIR)/tclIntPlatDecls.h $(GENERIC_DIR)/tclPort.h \
 	$(GENERIC_DIR)/tclOOInt.h $(GENERIC_DIR)/tclOOIntDecls.h \
-	$(UNIX_DIR)/tclUnixPort.h
+	$(UNIX_DIR)/tclUnixPort.h $(GENERIC_DIR)/tclCompile.h
